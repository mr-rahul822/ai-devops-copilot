# ═══════════════════════════════════════════════════════════════
# AI DevOps Copilot — Cloud Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NOTE: No permanent AWS credentials are needed anymore!
# The platform uses IAM Role ARN + STS AssumeRole.
# Users configure their Role ARN through the Cloud Configuration UI.
#
# PLATFORM_ACCOUNT_ID is YOUR platform's AWS account ID.
# It is embedded in the Trust Policy that users must configure.
# ═══════════════════════════════════════════════════════════════

PLATFORM_ACCOUNT_ID=482624378370
AWS_DEFAULT_REGION=us-east-1
