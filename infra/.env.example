# ═══════════════════════════════════════════════════════════════
# AI DevOps Copilot — AWS Credentials Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# These credentials are used by metrics-service (CloudWatch reads)
# and action-service (EC2 remediation actions).
#
# IAM policy required:
#   cloudwatch:GetMetricStatistics, cloudwatch:ListMetrics,
#   cloudwatch:GetMetricData, ec2:DescribeInstances,
#   ec2:DescribeInstanceStatus, ec2:RebootInstances,
#   autoscaling:Describe/Update, logs:FilterLogEvents, etc.
# ═══════════════════════════════════════════════════════════════

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
